CREATE OR REPLACE VIEW bme.reports.composition_open_view AS
SELECT
    date_parse(date,'%d.%m.%Y')                              AS date,
    date_parse(next_trading_day,'%d.%m.%Y')                  AS next_trading_day,

    TRY_CAST(index_symbol AS INTEGER)                        AS index_symbol,
    index_name,
    index_isin,
    index_type,
    index_currency,

    TRY_CAST(index_component_count AS INTEGER)               AS index_component_count,
    TRY_CAST(index_float AS DOUBLE)                          AS index_float,
    TRY_CAST(index_mcap_units AS BIGINT)                     AS index_mcap_units,
    TRY_CAST(index_divisor AS DOUBLE)                        AS index_divisor,

    TRY_CAST(valor_number AS BIGINT)                         AS valor_number,
    isin,
    ric,
    instrument_symbol,
    instrument_name,

    country,
    currency,
    exchange,

    TRY_CAST(six_classification AS INTEGER)                  AS six_classification,
    TRY_CAST(shares AS BIGINT)                               AS shares,
    TRY_CAST(free_float AS DOUBLE)                           AS free_float,
    TRY_CAST(capfactor AS DOUBLE)                            AS capfactor,
    TRY_CAST(weightfactor AS DOUBLE)                         AS weightfactor,
    TRY_CAST(ci_factor AS DOUBLE)                            AS ci_factor,

    TRY_CAST(close_unadjusted_local AS DOUBLE)               AS close_unadjusted_local,
    TRY_CAST(close_adjusted_local AS DOUBLE)                 AS close_adjusted_local,

    TRY_CAST(fx_local_to_index_currency AS DOUBLE)           AS fx_local_to_index_currency,

    TRY_CAST(mcap_units_local AS DOUBLE)                     AS mcap_units_local,
    TRY_CAST(mcap_units_index_currency AS DOUBLE)            AS mcap_units_index_currency,

    TRY_CAST(weight AS DOUBLE)                               AS weight,

    TRY_CAST(cash_dividend_amount AS DOUBLE)                 AS cash_dividend_amount,
    cash_dividend_currency,

    TRY_CAST(special_cash_dividend_amount AS DOUBLE)         AS special_cash_dividend_amount,
    special_cash_dividend_currency,

    corporate_action_description
FROM bme.reports.composition_open;